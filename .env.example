# ============================================================================
# Spider — пример конфигурации. Скопируйте в .env и заполните.
# В проде эти значения приходят из GitHub Actions secrets, а не из репозитория.
# ============================================================================

# --- Административный доступ (панель + admin API) ---
# Сильный случайный токен. НИКОГДА не коммитьте реальное значение.
SPIDER_ADMIN_KEY=change-me-to-a-long-random-string

# --- Сеть ---
SPIDER_HTTP_ADDR=:8080
# Публичный URL панели (без слеша на конце). Caddy терминирует TLS.
SPIDER_PUBLIC_URL=https://spider.lowkey.su

# --- Хранилище ---
SPIDER_DB_PATH=/var/lib/spider/spider.db

# --- Клиентский транспорт ---
# Сколько секунд сервер может держать long-poll открытым (0 = мгновенный ответ).
SPIDER_LONGPOLL_TIMEOUT=30
# Срок действия enrollment-токена (часы). 0 = бесконечно.
SPIDER_ENROLL_TTL_HOURS=24

# --- Логирование ---
# debug | info | warn | error
SPIDER_LOG_LEVEL=info

# --- Deploy (только для install.sh / CI, см. docs/DEPLOY.md) ---
# SSH_USER=root
# SSH_HOST=193.41.5.130
# Пароль SSH НЕ хранить в файле — только GitHub Actions secret SSH_PASSWORD.

# --- Подпись клиентских бинарей (CI only, ed25519) ---
# Приватный ключSIGNING_KEY только в GitHub Actions secret.
# Публичный ключ SIGNING_PUBKEY вшивается в клиент (client/src/update.rs).
