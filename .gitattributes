# Нормализация переносов строк: текстовые файлы хранятся в репо с LF.
* text=auto eol=lf

# Явно бинарные
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.db binary
*.sqlite binary

# Скрипты под Windows/bash — LF тоже ок
*.sh text eol=lf
*.ps1 text eol=crlf
